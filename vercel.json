{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/journey", "destination": "/journey.html" },
    { "source": "/projects", "destination": "/projects.html" },
    { "source": "/blogs", "destination": "/blogs.html" },
    { "source": "/life", "destination": "/life.html" },
    { "source": "/agent", "destination": "/agent.html" }
  ]
}
